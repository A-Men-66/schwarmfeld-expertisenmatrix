# Datenbank (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/schwarmfeld_sd

# JWT-Sicherheitsschlüssel (zufälliger langer String)
JWT_SECRET=hier_einen_langen_zufaelligen_string_eintragen

# Admin-Account (wird beim ersten Start angelegt)
ADMIN_EMAIL=admin@beispiel.de
ADMIN_PASSWORD=sicheres_passwort_hier

# Mail (optional, via Brevo SMTP)
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
MAIL_FROM=

# Port (optional, Standard: 3006)
PORT=3006
